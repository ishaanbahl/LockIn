{
  "expo": {
    "name": "Lok",
    "slug": "LockIn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "lockin",
    "splash": {
      "image": "./assets/lok-mascot.png",
      "resizeMode": "contain",
      "backgroundColor": "#08542F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ishaanbahl.lockin",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "LockIn needs notifications to remind you about incomplete tasks."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "@react-native-community/datetimepicker",
      "./plugins/withScreenTime"
    ]
  }
}